#pragma once

class Thing;

class Component{
public:
    Thing *thing_ptr = nullptr;
    std::string test = "rar";

    Component(Thing* ptr){
        this->thing_ptr = ptr;
    }


    void tick(){
        print("Component tick!");
    }
};

class Player : public Component {
public:
    Player(Thing* ptr) : Component(ptr){}

    void tick(){
        print("Player tick");
        switch(cross_screen_buffer["PlayerCom"]) {
            case 1:
                print("move_up");
            break;
            case 2:
                print("move_down");
            break;
            case 3:
                print("move_left");
            break;
            case 4:
                print("move_right");
            break;
        }
    }

};
